FINNHUB_MIN_INTERVAL_SECONDS=1.1
SECRET_KEY=replace-with-a-random-secret-of-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ACCESS_TOKEN_COOKIE_NAME=alphaforge_access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
