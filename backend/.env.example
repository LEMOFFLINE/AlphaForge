DATABASE_URL=postgresql://postgres:password@localhost:5432/alphaforge
REDIS_URL=redis://localhost:6379/0
STOCK_CACHE_TTL_SECONDS=7200
STOCK_CACHE_REFRESH_INTERVAL_SECONDS=3600
STOCK_TREND_RETENTION_DAYS=8
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
